BENCH_HOST=benchmark_db
BENCH_PORT=5432
BENCH_NAME=benchmark_res
BENCH_USER=postgres
BENCH_PASSWORD=123
BENCH_POSTGRES_DATA_DIR=/var/lib/postgresql/data
BENCH_CONTAINER_NAME=benchmark_db

# Target Database (to be tuned)
TARGET_DB_HOST=timescaledb
TARGET_DB_PORT=5432
TARGET_DB_NAME=monitor
TARGET_DB_USER=postgres
TARGET_DB_PASSWORD=123
#TARGET_POSTGRES_CONF_PATH=/var/lib/postgresql/data/postgresql.conf
TARGET_POSTGRES_CONF_PATH=/app/config/postgresql.conf
TARGET_POSTGRES_DATA_DIR=/var/lib/postgresql/data/pgdata
TARGET_CONTAINER_NAME=timescaledb

# TSBS Benchmark Configuration
TSBS_BIN_PATH=/usr/local/bin
TSBS_WORKERS=4
TSBS_BATCH_SIZE=10000
TSBS_SCALE=100
TSBS_DURATION=300

# Optimization Configuration
OPTIMIZATION_BUDGET=30
INITIAL_SAMPLES=5
ACQUISITION_FUNCTION=EI

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# System Resources
SYSTEM_RAM_GB=32
SYSTEM_CPU_CORES=8
SYSTEM_DISK_TYPE=ssd

RES_DIR=results
QUERIES_DIR=tsbs_data


TARGET_DB_DSN=host=timescaledb dbname=monitor user=postgres password=123 port=5432
RESULTS_DB_DSN=host=benchmark_db dbname=benchmark_res user=postgres password=123 port=5432
TUNER_CONFIG=/app/config/tuner.yml
BENCHMARK_WORKER_URL=http://tsbs-runner:8080


GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
DOCKER_GID=984
MONITOR_CONTAINERS=timescaledb,benchmark_db,tsbs-runner
